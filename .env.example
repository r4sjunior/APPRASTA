# Supabase (Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Chave "service_role" — dá acesso total ao banco, NUNCA prefixe com NEXT_PUBLIC_
# e nunca exponha no client. Só é usada em código de servidor (API routes, server components).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Segredo usado para assinar o cookie de sessão (login de admin/lojas).
# Gere um valor aleatório longo, ex: openssl rand -base64 32
SESSION_SECRET=troque-por-um-segredo-aleatorio-longo
