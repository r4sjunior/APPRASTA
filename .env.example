# Supabase (Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Chave "service_role" — dá acesso total ao banco, NUNCA prefixe com NEXT_PUBLIC_
# e nunca exponha no client. Só é usada em código de servidor (API routes, server components).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Protege o app inteiro com HTTP Basic Auth (usuário/senha únicos, sem cadastro).
APP_USER=admin
APP_PASSWORD=troque-esta-senha
